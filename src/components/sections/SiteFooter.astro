---
import type { FooterContent, BrandContent } from "@/content/site-content";

interface Props {
  brand: BrandContent;
  footer: FooterContent;
}

const { brand, footer } = Astro.props;
---

<footer class="py-10 md:py-12 border-t border-border bg-background">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="text-center md:text-left">
        <div class="font-bold text-foreground">{brand.name}</div>
        <p class="mt-1 text-sm text-muted-foreground">{footer.copyright}</p>
      </div>

      <div class="flex items-center gap-6">
        {
          footer.links.map((link) => (
            <a
              href={link.href}
              class="text-sm text-muted-foreground hover:text-foreground transition-colors"
            >
              {link.label}
            </a>
          ))
        }
      </div>

      {
        footer.socials && footer.socials.length > 0 && (
          <div class="flex items-center gap-4">
            {footer.socials.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.platform}
                class="text-muted-foreground hover:text-foreground transition-colors"
              >
                <span class="text-sm font-medium capitalize">{social.platform}</span>
              </a>
            ))}
          </div>
        )
      }
    </div>
  </div>
</footer>
