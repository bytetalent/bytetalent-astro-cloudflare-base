---
import type { FeaturesContent } from "@/content/site-content";

interface Props {
  features: FeaturesContent;
}

const { features } = Astro.props;
---

<section id="features" class="py-16 md:py-20 bg-muted/30">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mx-auto max-w-[680px] text-center">
      <h2 class="text-section-heading">{features.title}</h2>
      {features.subtitle && <p class="mt-4 text-lg text-muted-foreground">{features.subtitle}</p>}
    </div>

    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        features.items.map((item) => (
          <div class="rounded-2xl border border-border bg-background p-7 hover:shadow-md transition-shadow">
            {item.icon && <div class="mb-4 text-3xl">{item.icon}</div>}
            <h3 class="text-lg font-semibold text-foreground">{item.title}</h3>
            <p class="mt-2 text-sm text-muted-foreground leading-relaxed">{item.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
