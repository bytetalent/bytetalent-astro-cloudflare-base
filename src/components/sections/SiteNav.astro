---
import type { NavContent, BrandContent } from "@/content/site-content";

interface Props {
  brand: BrandContent;
  nav: NavContent;
}

const { brand, nav } = Astro.props;
---

<nav class="sticky top-0 z-50 h-[72px] border-b border-border bg-background/80 backdrop-blur-md">
  <div class="mx-auto flex h-full max-w-[1200px] items-center justify-between px-6">
    <a href="/" class="flex items-center gap-2 font-bold text-lg text-foreground">
      {brand.logoUrl && <img src={brand.logoUrl} alt={brand.name} class="h-7 w-auto" />}
      {!brand.logoUrl && <span>{brand.name}</span>}
    </a>

    <ul class="hidden md:flex items-center gap-6">
      {
        nav.links.map((link) => (
          <li>
            <a href={link.href} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      {
        nav.signInLabel && nav.signInHref && (
          <a href={nav.signInHref} class="text-sm font-medium text-foreground hover:opacity-80">
            {nav.signInLabel}
          </a>
        )
      }
      <a
        href={nav.primaryCta.href}
        class="inline-flex h-9 items-center rounded-lg bg-primary px-4 text-sm font-medium text-primary-foreground hover:opacity-90 transition-opacity"
      >
        {nav.primaryCta.label}
      </a>
    </div>
  </div>
</nav>
