---
import type { HeroContent } from "@/content/site-content";

interface Props {
  hero: HeroContent;
}

const { hero } = Astro.props;
---

<section class="py-20 md:py-24">
  <div class="mx-auto max-w-[1200px] px-6">
    <div class="mx-auto max-w-[800px] text-center">
      {
        hero.eyebrow && (
          <p class="mb-4 text-sm font-medium uppercase tracking-wider text-primary">
            {hero.eyebrow}
          </p>
        )
      }
      <h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-foreground leading-[1.1]">
        {hero.title}
      </h1>
      <p class="mt-6 text-lg md:text-xl text-muted-foreground leading-relaxed">
        {hero.subtitle}
      </p>
      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={hero.primaryCta.href}
          class="inline-flex h-12 items-center justify-center rounded-lg bg-primary px-6 text-base font-medium text-primary-foreground hover:opacity-90 transition-opacity w-full sm:w-auto"
        >
          {hero.primaryCta.label}
        </a>
        {
          hero.secondaryCta && (
            <a
              href={hero.secondaryCta.href}
              class="inline-flex h-12 items-center justify-center rounded-lg border border-border bg-background px-6 text-base font-medium text-foreground hover:bg-muted transition-colors w-full sm:w-auto"
            >
              {hero.secondaryCta.label}
            </a>
          )
        }
      </div>
      {
        hero.imageUrl && (
          <div class="mt-16">
            <img
              src={hero.imageUrl}
              alt={hero.imageAlt ?? ""}
              class="w-full rounded-2xl border border-border shadow-2xl"
              loading="eager"
            />
          </div>
        )
      }
    </div>
  </div>
</section>
