---
import type { TeamContent } from "@/content/site-content";

interface Props {
  team: TeamContent;
}

const { team } = Astro.props;
---

<section class="py-16 md:py-20 bg-muted/30">
  <div class="mx-auto max-w-[1200px] px-6">
    {team.title && <h2 class="text-section-heading text-center mb-12">{team.title}</h2>}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {
        team.members.map((member) => (
          <div class="rounded-2xl border border-border bg-background p-7 text-center">
            <div class="mx-auto h-20 w-20 rounded-full bg-muted overflow-hidden">
              {member.imageUrl && (
                <img
                  src={member.imageUrl}
                  alt={member.name}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              )}
            </div>
            <h3 class="mt-4 text-base font-semibold text-foreground">{member.name}</h3>
            <p class="mt-1 text-sm text-muted-foreground">{member.role}</p>
            {member.bio && (
              <p class="mt-3 text-sm text-muted-foreground leading-relaxed">{member.bio}</p>
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
