# Resend transactional email — required in production for the contact form.
# Sign up at https://resend.com, verify your sending domain, copy the API key.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where contact-form submissions are delivered.
CONTACT_TO_EMAIL=hello@yourcompany.com

# Verified sending address (must match a verified domain in Resend).
CONTACT_FROM_EMAIL=contact@yourcompany.com

# Public site URL — used for canonical links + OG metadata.
PUBLIC_SITE_URL=https://marketing.yourcompany.com
